local function startFly()
	local char=Player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end
	local root=char.HumanoidRootPart
	local hum=char:FindFirstChild("Humanoid")
	if not hum then return end
	hum.PlatformStand=true
	flyingBodyGyro=Instance.new("BodyGyro")
	flyingBodyGyro.Name="FlyGyro"
	flyingBodyGyro.P=0
	flyingBodyGyro.MaxTorque=Vector3.new(0,0,0)
	flyingBodyGyro.CFrame=Camera.CFrame
	flyingBodyGyro.Parent=root
	flyingBodyVel=Instance.new("BodyVelocity")
	flyingBodyVel.Name="FlyVel"
	flyingBodyVel.Velocity=Vector3.zero
	flyingBodyVel.MaxForce=Vector3.new(4000,4000,4000)
	flyingBodyVel.Parent=root
	flyKeys={W=false,A=false,S=false,D=false,E=false,Q=false}
	local function updateMove()
		local moveDir=Vector3.zero
		if flyKeys.W then moveDir=moveDir+Camera.CFrame.LookVector end
		if flyKeys.S then moveDir=moveDir-Camera.CFrame.LookVector end
		if flyKeys.A then moveDir=moveDir-Camera.CFrame.RightVector end
		if flyKeys.D then moveDir=moveDir+Camera.CFrame.RightVector end
		if flyKeys.E then moveDir=moveDir+Vector3.new(0,1,0) end
		if flyKeys.Q then moveDir=moveDir+Vector3.new(0,-1,0) end
		if moveDir.Magnitude>0 then moveDir=moveDir.Unit end
		if flyingBodyVel and flyingBodyVel.Parent then
			flyingBodyVel.Velocity=moveDir*flySpeed
		end
		if flyingBodyGyro and flyingBodyGyro.Parent then
			flyingBodyGyro.CFrame=Camera.CFrame
		end
	end
	flyConn=RunService.RenderStepped:Connect(updateMove)
	local keyBegan
	local keyEnded
	keyBegan=UIS.InputBegan:Connect(function(i,gp)
		if gp then return end
		if i.KeyCode==Enum.KeyCode.W then flyKeys.W=true
		elseif i.KeyCode==Enum.KeyCode.A then flyKeys.A=true
		elseif i.KeyCode==Enum.KeyCode.S then flyKeys.S=true
		elseif i.KeyCode==Enum.KeyCode.D then flyKeys.D=true
		elseif i.KeyCode==Enum.KeyCode.E then flyKeys.E=true
		elseif i.KeyCode==Enum.KeyCode.Q then flyKeys.Q=true
		end
	end)
	keyEnded=UIS.InputEnded:Connect(function(i,gp)
		if gp then return end
		if i.KeyCode==Enum.KeyCode.W then flyKeys.W=false
		elseif i.KeyCode==Enum.KeyCode.A then flyKeys.A=false
		elseif i.KeyCode==Enum.KeyCode.S then flyKeys.S=false
		elseif i.KeyCode==Enum.KeyCode.D then flyKeys.D=false
		elseif i.KeyCode==Enum.KeyCode.E then flyKeys.E=false
		elseif i.KeyCode==Enum.KeyCode.Q then flyKeys.Q=false
		end
	end)
end

local function stopFly()
	if flyingBodyGyro then flyingBodyGyro:Destroy() flyingBodyGyro=nil end
	if flyingBodyVel then flyingBodyVel:Destroy() flyingBodyVel=nil end
	if flyConn then flyConn:Disconnect() flyConn=nil end
	if Player.Character and Player.Character:FindFirstChild("Humanoid") then
		Player.Character.Humanoid.PlatformStand=false
	end
end

