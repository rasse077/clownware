            end
        end
        coroutine.wrap(rapidFireLoop)()
    end
    
    if weaponNoSpread then
        local module=nil
        for _,v in pairs(getgc(true)) do
            if type(v)=="table" and rawget(v,"Spread") and type(rawget(v,"Spread"))=="number" then
                module=v
                break
            end
        end
        if module then
            if not originalWeaponProperties[weapon] then
                originalWeaponProperties[weapon]={}
            end
            if module.Spread then
                originalWeaponProperties[weapon].Spread=module.Spread
                module.Spread=0
            end
        end
    end
    
    if weaponInstantReload then
        local function checkReload()
            local backpack=Player:FindFirstChild("Backpack")
            if backpack then
                for _,tool in ipairs(backpack:GetChildren()) do
                    if tool:IsA("Tool") and tool:FindFirstChild("Ammo") then
                        tool.Ammo.Value=tool.Ammo:FindFirstChild("MaxValue") and tool.Ammo.MaxValue or 999
                    end
                end
            end
            if weapon and weapon:FindFirstChild("Ammo") then
                weapon.Ammo.Value=weapon.Ammo:FindFirstChild("MaxValue") and weapon.Ammo.MaxValue or 999
            end
        end
        coroutine.wrap(function()
            while weaponInstantReload and weaponModsEnabled and weapon and weapon.Parent do
                checkReload()
                task.wait(0.1)
            end
        end)()
    end
    
    if weaponDamageMultiplier~=1 then
        local function modifyDamage()
            for _,v in pairs(getgc(true)) do
                if type(v)=="table" and rawget(v,"Damage") and type(rawget(v,"Damage"))=="number" then
                    if not originalWeaponProperties[weapon] then
                        originalWeaponProperties[weapon]={}
                    end
                    if not originalWeaponProperties[weapon].Damage then
                        originalWeaponProperties[weapon].Damage=v.Damage
                    end
                    v.Damage=originalWeaponProperties[weapon].Damage*weaponDamageMultiplier
                end
            end
        end
        coroutine.wrap(modifyDamage)()
    end
end

local function removeWeaponMods(weapon)
    if not weapon then return end
    if noWeaponDelay and weapon:FindFirstChild("Enabled") then
        weapon.Enabled=true
    end
    if weaponNoSpread and originalWeaponProperties[weapon] and originalWeaponProperties[weapon].Spread then
        for _,v in pairs(getgc(true)) do
            if type(v)=="table" and rawget(v,"Spread") then
                v.Spread=originalWeaponProperties[weapon].Spread
                break
            end
        end
    end
    if weaponDamageMultiplier~=1 and originalWeaponProperties[weapon] and originalWeaponProperties[weapon].Damage then
        for _,v in pairs(getgc(true)) do
            if type(v)=="table" and rawget(v,"Damage") and rawget(v,"Damage")~=originalWeaponProperties[weapon].Damage then
                v.Damage=originalWeaponProperties[weapon].Damage
                break
            end
        end
    end
end

