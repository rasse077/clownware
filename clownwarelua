	if damageSlider then damageSlider.Set(currentDamage) end
	if fireRateSlider then fireRateSlider.Set(currentFireRate) end
	if rangeSlider then rangeSlider.Set(currentRange) end
	
	blurOn=data.blurOn
	fieldOfView=data.fieldOfView or 70
	watermarkEnabled=data.watermarkEnabled
	
	if blurOn then
		blurToggle.Text="✓"
		if main.Visible then
