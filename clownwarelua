local function applyTheme(themeName)
	for _,t in ipairs(themes) do
		if t.name==themeName then
			currentTheme=themeName
			if themeName=="Rainbow" then
				if rainbowConn then rainbowConn:Disconnect() end
				rainbowConn=RunService.RenderStepped:Connect(function()
					rainbowHue=(rainbowHue+0.005)%1
					local rainbowColor=Color3.fromHSV(rainbowHue,1,1)
					main.BackgroundColor3=rainbowColor
					top.BackgroundColor3=rainbowColor
					left.BackgroundColor3=rainbowColor
					content.BackgroundColor3=rainbowColor
					bottom.BackgroundColor3=rainbowColor
					for _,btn in ipairs(tabButtons) do
						if btn.BackgroundColor3~=Color3.fromRGB(22,22,22) then
							btn.BackgroundColor3=rainbowColor
						end
					end
				end)
			else
				if rainbowConn then rainbowConn:Disconnect() rainbowConn=nil end
				main.BackgroundColor3=t.bg
				top.BackgroundColor3=t.fg
				left.BackgroundColor3=t.bg
				content.BackgroundColor3=t.fg
				bottom.BackgroundColor3=t.fg
				for _,btn in ipairs(tabButtons) do
					if btn.BackgroundColor3~=Color3.fromRGB(22,22,22) then
						btn.BackgroundColor3=t.bg
					end
				end
				if themeName=="Transparent" then
					main.BackgroundTransparency=0.5
					top.BackgroundTransparency=0.5
					left.BackgroundTransparency=0.5
					content.BackgroundTransparency=0.5
					bottom.BackgroundTransparency=0.5
				else
					main.BackgroundTransparency=0
					top.BackgroundTransparency=0
					left.BackgroundTransparency=0
					content.BackgroundTransparency=0
					bottom.BackgroundTransparency=0
				end
			end
			break
		end
	end
end

