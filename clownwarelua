local function updateESPVisuals()
	for _,plr in ipairs(Players:GetPlayers()) do
		if plr~=Player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health>0 then
			local root=plr.Character.HumanoidRootPart
			local head=plr.Character:FindFirstChild("Head") or root
			local screenPos,onScreen=Camera:WorldToViewportPoint(root.Position)
			local headPos,headOn=Camera:WorldToViewportPoint(head.Position)
			
			if onScreen and boxEspEnabled then
				local height=math.abs(headPos.Y-screenPos.Y)
				local width=height*0.6
				local boxObj=boxes[plr]
				if not boxObj then
					boxObj=Drawing.new("Square")
					boxObj.Thickness=1
					boxObj.Transparency=0.5
					boxes[plr]=boxObj
				end
				boxObj.Visible=true
				boxObj.Color=espColor
				boxObj.Size=Vector2.new(width,height)
				boxObj.Position=Vector2.new(screenPos.X-width/2,screenPos.Y-height)
			elseif boxes[plr] then
				boxes[plr].Visible=false
			end
			
			if onScreen and healthBarEnabled then
				local health=plr.Character.Humanoid.Health/plr.Character.Humanoid.MaxHealth
				local height=math.abs(headPos.Y-screenPos.Y)
				local width=height*0.6
				local bar=healthBars[plr]
				if not bar then
					bar=Drawing.new("Square")
					bar.Thickness=1
					bar.Filled=true
					bar.Transparency=0.3
					healthBars[plr]=bar
				end
				bar.Visible=true
				bar.Color=Color3.fromRGB(0,255,0)
				bar.Size=Vector2.new(3,height*health)
				bar.Position=Vector2.new(screenPos.X-width/2-5,screenPos.Y-height+(height*(1-health)))
			elseif healthBars[plr] then
				healthBars[plr].Visible=false
			end
			
			if onScreen and nameTagsEnabled then
				local nameTag=nameTags[plr]
				if not nameTag then
					nameTag=Drawing.new("Text")
					nameTag.Size=14
					nameTag.Center=true
					nameTag.Outline=true
					nameTag.OutlineColor=Color3.fromRGB(0,0,0)
					nameTags[plr]=nameTag
				end
				nameTag.Visible=true
				nameTag.Color=espColor
				nameTag.Text=plr.Name
				nameTag.Position=Vector2.new(screenPos.X,screenPos.Y-50)
			elseif nameTags[plr] then
				nameTags[plr].Visible=false
			end
		end
	end
end

local function addHighlight(character)
	if not character then return end
	if character:FindFirstChild("ClownESP") then
		character.ClownESP.OutlineColor=espColor
		return
	end
	local highlight=Instance.new("Highlight")
	highlight.Name="ClownESP"
	highlight.FillTransparency=1
	highlight.OutlineColor=espColor
	highlight.OutlineTransparency=0
	highlight.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent=character
end

local function updateAllHighlights()
	for _,plr in ipairs(Players:GetPlayers()) do
		if plr~=Player and plr.Character and plr.Character:FindFirstChild("ClownESP") then
			plr.Character.ClownESP.OutlineColor=espColor
		end
	end
end

local function refreshAllESP()
	if not espEnabled then return end
	for _,plr in ipairs(Players:GetPlayers()) do
		if plr~=Player and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health>0 then
			if plr.Character:FindFirstChild("ClownESP") then
				plr.Character.ClownESP.OutlineColor=espColor
			else
				addHighlight(plr.Character)
			end
		end
	end
end

local function updateTracers()
	for plr,drawing in pairs(tracers) do
		if drawing then
			drawing.Visible=false
			drawing:Remove()
			tracers[plr]=nil
		end
	end
	if not tracersEnabled then return end
	for _,plr in ipairs(Players:GetPlayers()) do
		if plr~=Player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health>0 then
			local root=plr.Character.HumanoidRootPart
			local screenPos,onScreen=Camera:WorldToViewportPoint(root.Position)
			if onScreen then
				local line=Drawing.new("Line")
				line.Color=tracerColor
				line.Thickness=1
				line.Transparency=0.5
				line.From=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y)
				line.To=Vector2.new(screenPos.X,screenPos.Y)
				line.Visible=true
				tracers[plr]=line
			end
		end
	end
end

