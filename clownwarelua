local configName="ClownwareConfig"
local function saveConfig()
	local config={
		aimbotEnabled=aimbotEnabled,
		triggerBotEnabled=triggerBotEnabled,
		aimbotTarget=aimbotTarget,
		aimbotFov=aimbotFov,
		aimbotSmoothness=aimbotSmoothness,
		targetIdx=targetIdx,
		flyEnabled=flyEnabled,
		flySpeed=flySpeed,
		superJumpEnabled=superJumpEnabled,
		noClipEnabled=noClipEnabled,
		superSprintEnabled=superSprintEnabled,
		superSprintSpeed=superSprintSpeed,
		rapidFireEnabled=rapidFireEnabled,
		espEnabled=espEnabled,
		espColorR=espColor.R,
		espColorG=espColor.G,
		espColorB=espColor.B,
		tracersEnabled=tracersEnabled,
		tracerColorR=tracerColor.R,
		tracerColorG=tracerColor.G,
		tracerColorB=tracerColor.B,
		fovCircleEnabled=fovCircleEnabled,
		fovCircleColorR=fovCircleColor.R,
		fovCircleColorG=fovCircleColor.G,
		fovCircleColorB=fovCircleColor.B,
		fovRadius=fovRadius,
		blurOn=blurOn,
		fieldOfView=fieldOfView,
		watermarkEnabled=watermarkEnabled,
		autoExecuteEnabled=autoExecuteEnabled,
		currentTheme=currentTheme
	}
	if writefile and isfile then
		writefile(configName..".json",game:GetService("HttpService"):JSONEncode(config))
	end
end

local function loadConfig()
	if not isfile or not isfile(configName..".json") then return end
	local success,data=pcall(function()
		return game:GetService("HttpService"):JSONDecode(readfile(configName..".json"))
	end)
	if not success or not data then return end
	
	aimbotEnabled=data.aimbotEnabled
	triggerBotEnabled=data.triggerBotEnabled
	aimbotTarget=data.aimbotTarget or "Head"
	aimbotFov=data.aimbotFov or 200
	aimbotSmoothness=data.aimbotSmoothness or 0.15
	targetIdx=data.targetIdx or 1
	if aimbotCB then aimbotCB.Set(aimbotEnabled) end
	if triggerBotCB then triggerBotCB.Set(triggerBotEnabled) end
	if aimbotDropdown then aimbotDropdown.Text=aimbotTarget end
	if aimbotFovSlider then aimbotFovSlider.Set(aimbotFov) end
	if aimbotSmoothSlider then aimbotSmoothSlider.Set(aimbotSmoothness) end
	
	flyEnabled=data.flyEnabled
	flySpeed=data.flySpeed or 50
	superJumpEnabled=data.superJumpEnabled
	noClipEnabled=data.noClipEnabled
	superSprintEnabled=data.superSprintEnabled
	superSprintSpeed=data.superSprintSpeed or 30
	rapidFireEnabled=data.rapidFireEnabled
	
	if flyCB then flyCB.Set(flyEnabled) end
	if flySpeedSlider then flySpeedSlider.Set(flySpeed) end
	if superJumpCB then superJumpCB.Set(superJumpEnabled) end
	if noClipCB then noClipCB.Set(noClipEnabled) end
	if superSprintCB then superSprintCB.Set(superSprintEnabled) end
	if superSprintSlider then superSprintSlider.Set(superSprintSpeed) end
	if rapidFireCB then rapidFireCB.Set(rapidFireEnabled) end
	
	if superJumpEnabled and Player.Character and Player.Character:FindFirstChild("Humanoid") then
		Player.Character.Humanoid.JumpPower=200
	end
	if superSprintEnabled and Player.Character and Player.Character:FindFirstChild("Humanoid") then
		Player.Character.Humanoid.WalkSpeed=superSprintSpeed
	end
	
	if flyEnabled then
		stopFly()
		wait(0.2)
		startFly()
	end
	
	if rapidFireEnabled then
		if rapidFireConn then
			rapidFireConn:Disconnect()
			rapidFireConn=nil
		end
		rapidFireConn=RunService.RenderStepped:Connect(function()
			if rapidFireEnabled and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
				fireTool()
			end
		end)
	end
	
	espEnabled=data.espEnabled
	espColor=Color3.fromRGB(data.espColorR or 0,data.espColorG or 0,data.espColorB or 0)
	tracersEnabled=data.tracersEnabled
	tracerColor=Color3.fromRGB(data.tracerColorR or 255,data.tracerColorG or 255,data.tracerColorB or 255)
	fovCircleEnabled=data.fovCircleEnabled
	fovCircleColor=Color3.fromRGB(data.fovCircleColorR or 0,data.fovCircleColorG or 0,data.fovCircleColorB or 0)
	fovRadius=data.fovRadius or 200
	
	if espCB then espCB.Set(espEnabled) end
	if tracersCB then tracersCB.Set(tracersEnabled) end
	if fovCircleCB then fovCircleCB.Set(fovCircleEnabled) end
	if fovRadiusSlider then fovRadiusSlider.Set(fovRadius) end
	
	if espEnabled then
		refreshAllESP()
		if espRefreshConn then espRefreshConn:Disconnect() end
		espRefreshConn=RunService.Heartbeat:Connect(function()
			refreshAllESP()
			wait(1)
		end)
	end
	
	blurOn=data.blurOn
	fieldOfView=data.fieldOfView or 70
	watermarkEnabled=data.watermarkEnabled
	autoExecuteEnabled=data.autoExecuteEnabled
	
	if blurOn then
		blurToggle.Text="✓"
		if main.Visible then
			blur.Enabled=true
			TweenService:Create(blur,TweenInfo.new(.2),{Size=18}):Play()
		end
	end
	if fovSlider then fovSlider.Set(fieldOfView) end
	Camera.FieldOfView=fieldOfView
	if watermarkCB then watermarkCB.Set(watermarkEnabled) end
	if watermarkGui then 
		watermarkGui.Enabled=watermarkEnabled
	end
	if autoExecuteCB then autoExecuteCB.Set(autoExecuteEnabled) end
	
	if data.currentTheme then
		applyTheme(data.currentTheme)
	end
end

