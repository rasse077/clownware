local function copyToClipboard(text)
	local success=false
	if setclipboard then
		setclipboard(text)
		success=true
	elseif toclipboard then
		toclipboard(text)
		success=true
	elseif syn and syn.clipboard then
		syn.clipboard(text)
		success=true
	elseif Clipboard then
		Clipboard(text)
		success=true
	end
	return success
end

local function checkbox(p,x,y,text,callback)
	local box=frame(p,x,y,18,18,Color3.fromRGB(16,16,16))
	round(box,4)
	stroke(box,1,Color3.fromRGB(55,55,55),0)
	local check=txt(box,"✓",16,0,0,18,18,Color3.fromRGB(0,255,100),Enum.Font.Code,Enum.TextXAlignment.Center)
	check.Visible=false
	local lbl=txt(p,text,14,x+26,y+1,200,18,Color3.fromRGB(230,230,230),Enum.Font.Code)
	local state=false
	local function toggle()
		state=not state
		check.Visible=state
		if callback then callback(state) end
	end
	box.InputBegan:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 then
			toggle()
		end
	end)
	lbl.InputBegan:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 then
			toggle()
		end
	end)
	return {
		box=box,
		check=check,
		lbl=lbl,
		Set=function(v)
			state=v
			check.Visible=v
			if callback then callback(v) end
		end,
		Get=function() return state end
	}
end

local function slider(p,x,y,w,min,max,default,callback)
	local track=frame(p,x,y,w,6,Color3.fromRGB(30,30,30))
	round(track,3)
	local fill=frame(track,0,0,0,6,Color3.fromRGB(255,255,255))
	round(fill,3)
	local knob=frame(track,0,-5,12,16,Color3.fromRGB(255,255,255))
	round(knob,4)
	knob.AnchorPoint=Vector2.new(0.5,0)
	local val=txt(p,tostring(default),14,x+w+10,y-3,40,16,Color3.fromRGB(200,200,200),Enum.Font.Code)
	local value=default
	local dragging=false
	local function updateKnob()
		local percent=(value-min)/(max-min)
		fill.Size=UDim2.new(percent,0,1,0)
		knob.Position=UDim2.new(percent,0,0,0)
		val.Text=tostring(math.floor(value*10)/10)
	end
	updateKnob()
	knob.InputBegan:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 then
			dragging=true
		end
	end)
	UIS.InputEnded:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 then
			dragging=false
		end
	end)
	UIS.InputChanged:Connect(function(i)
		if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
			local mousePos=UIS:GetMouseLocation()
			local absPos=track.AbsolutePosition
			local absSize=track.AbsoluteSize
			local percent=math.clamp((mousePos.X-absPos.X)/absSize.X,0,1)
			value=min+percent*(max-min)
			value=math.floor(value*100)/100
			updateKnob()
			if callback then callback(value) end
		end
	end)
	return {
		Get=function() return value end,
		Set=function(v) value=v updateKnob() if callback then callback(v) end end,
		track=track
	}
end

