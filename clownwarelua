local dragging=false
local dragStart,startPos,dragInput

top.InputBegan:Connect(function(i)
	if i.UserInputType==Enum.UserInputType.MouseButton1 then
		dragging=true
		dragStart=i.Position
		startPos=main.Position
		i.Changed:Connect(function()
			if i.UserInputState==Enum.UserInputState.End then
				dragging=false
			end
		end)
	end
end)

top.InputChanged:Connect(function(i)
	if i.UserInputType==Enum.UserInputType.MouseMovement then
		dragInput=i
	end
end)

UIS.InputChanged:Connect(function(i)
	if dragging and i==dragInput then
		local d=i.Position-dragStart
		main.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
	end
end)

local open=true

local function setMenu(v)
	open=v
	main.Visible=v
	if v then
		UIS.MouseIconEnabled=false
		customCursor.Visible=true
		for _,trail in ipairs(cursorTrail) do
			trail.frame.Visible=true
		end
		if blurOn then
			blur.Enabled=true
			blur.Size=0
			TweenService:Create(blur,TweenInfo.new(.2),{Size=18}):Play()
		end
	else
		UIS.MouseIconEnabled=true
		customCursor.Visible=false
		for _,trail in ipairs(cursorTrail) do
			trail.frame.Visible=false
		end
		local tw=TweenService:Create(blur,TweenInfo.new(.2),{Size=0})
		tw:Play()
		tw.Completed:Connect(function()
			if not open then
				blur.Enabled=false
			end
		end)
	end
end

UIS.InputBegan:Connect(function(i,gp)
	if gp then return end
	if i.KeyCode==Enum.KeyCode.RightShift then
		setMenu(not open)
	end
end)

setMenu(true)
loadConfig()

RunService.Heartbeat:Connect(function()
	if boxEspEnabled or healthBarEnabled or nameTagsEnabled then
		updateESPVisuals()
	end
end)
