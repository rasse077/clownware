	if espEnabled then
		refreshAllESP()
		if espRefreshConn then espRefreshConn:Disconnect() end
		espRefreshConn=RunService.Heartbeat:Connect(function()
			refreshAllESP()
			wait(1)
		end)
	end
	
	weaponRapidFireEnabled=data.weaponRapidFireEnabled or false
	noFireCooldownEnabled=data.noFireCooldownEnabled or false
	infiniteAmmoEnabled=data.infiniteAmmoEnabled or false
	noRecoilEnabled=data.noRecoilEnabled or false
	noSpreadEnabled=data.noSpreadEnabled or false
	instantReloadEnabled=data.instantReloadEnabled or false
	currentDamage=data.currentDamage or 100
	currentFireRate=data.currentFireRate or 1
